models/
*.gguf
*.bin
*.safetensors
*.pt
*.ot

# OS / editors
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Results (large JSONs with raw outputs — не коммитим, только сводные таблицы)
results/raw/
