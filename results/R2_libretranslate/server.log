, '\u2581пакет', 'ы', '\u2581проходят', '\u2581через', '\u2581маршрутизатор', 'ы', '\u2581и', '\u2581ком', 'мут', 'а', 'торы', ',', '\u2581которые', '\u2581используют', '\u2581таблиц', 'ы', '\u2581маршрут', 'изации', '\u2581и', '\u2581таблиц', 'ы', '\u2581M', 'AC', '-', 'адрес', 'ов', '\u2581для', '\u2581эффективного', '\u2581пере', 'сыл', 'ки', '\u2581трафика', '.']], scores=[-3.0712101459503174], attention=[], logits=[]), TranslationResult(hypotheses=[['\u2581Механизм', 'ы', '\u2581качества', '\u2581обслуживания', '\u2581(', 'Q', 'o', 'S', ')', '\u2581от', 'дают', '\u2581приоритет', '\u2581чувствительн', 'ому', '\u2581к', '\u2581задержк', 'ам', '\u2581трафик', 'у', ',', '\u2581такому', '\u2581как', '\u2581голосов', 'ая', '\u2581и', '\u2581видео', '\u2581передача', '\u2581данных', '.']], scores=[-6.115117073059082], attention=[], logits=[])])
INFO:argostranslate.utils:('value_hypotheses:', [('Компьютерная сеть представляет собой набор взаимосвязанных устройств, которые обмениваются ресурсами и данными. Комплект протоколов TCP/IP формирует основу современного Интернета, работая на четырех уровнях: уровне связи, интернет-слое, транспортном уровне и прикладном уровне. Стандарт Ethernet регулирует связь локальной сети (LAN) с современными установками, поддерживающими скорости 1 Гбит/с, 10 Гбит/с или 100 Гбит/с. Беспроводные сети, основанные на стандарте IEEE 802.11 (Wi-Fi), обеспечивают мобильность, но, как правило, более низкую пропускную способность и большую задержку, чем проводные соединения. Сетевые пакеты проходят через маршрутизаторы и коммутаторы, которые используют таблицы маршрутизации и таблицы MAC-адресов для эффективного пересылки трафика. Механизмы качества обслуживания (QoS) отдают приоритет чувствительному к задержкам трафику, такому как голосовая и видео передача данных.', -26.883522510528564)])
